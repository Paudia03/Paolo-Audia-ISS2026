// LUCCIOLA 3
QActor firefly3 context ctxfirefly {
    [#
        var StartTime = 0L
        var BlinkTime = 400L 
        var SyncTime  = 1000L
        var IsSynced  = false
        var AlignTime = 0L
    #]

    State s0 initial {
        println("$name | start")
        [# StartTime = System.currentTimeMillis() #]
    }
    Goto flashOn

    State flashOn {
        [# var Elapsed = System.currentTimeMillis() - StartTime #]
        
        if [# Elapsed > 10000 && !IsSynced #] {
            [# 
               IsSynced = true 
               AlignTime = SyncTime - (System.currentTimeMillis() % SyncTime)
            #]
            println("$name | Sincronizzazione attivata! Allineamento fase in $AlignTime ms")
            delayVar AlignTime
            [# BlinkTime = SyncTime #]
        }

        println("$name | turnOn (delay=$BlinkTime)")
        color magenta
        forward griddisplay -m cellstate: cellstate(12,13,1)
        delayVar BlinkTime
    }
    Goto flashOff
    
    State flashOff {
        println("$name | turnOff")
        color cyan
        forward griddisplay -m cellstate: cellstate(12,13,0)
        delayVar BlinkTime
    }
    Goto flashOn
}


